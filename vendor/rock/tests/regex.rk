fn main() {
    // basic literal
    assert(regex.matches("hello", "hello world"))
    assert(not regex.matches("xyz", "hello world"))

    // dot, star, plus, question
    assert(regex.matches("h.llo", "hello"))
    assert(regex.matches("ab*c", "ac"))
    assert(regex.matches("ab*c", "abbbc"))
    assert(regex.matches("ab+c", "abc"))
    assert(not regex.matches("ab+c", "ac"))
    assert(regex.matches("colou?r", "color"))
    assert(regex.matches("colou?r", "colour"))

    // character classes
    assert(regex.matches("[abc]+", "cab"))
    assert(not regex.matches("^[abc]+$", "cad"))
    assert(regex.matches("[a-z]+", "hello"))
    assert(regex.matches("[^0-9]+", "abc"))

    // escape shorthands
    assert(regex.matches("\\d+", "abc 123 xyz"))
    assert(regex.matches("\\w+", "_var2"))
    assert(regex.matches("\\s+", "a  b"))

    // anchors
    assert(regex.matches("^hello", "hello world"))
    assert(not regex.matches("^world", "hello world"))
    assert(regex.matches("world$", "hello world"))

    // alternation
    assert(regex.matches("cat|dog", "I have a dog"))
    assert(regex.matches("cat|dog", "I have a cat"))

    // grouping
    assert(regex.matches("(ab)+", "abab"))

    // find
    assert_eq(regex.find("\\d+", "age=42 score=100"), "42")
    assert_eq(regex.find("xxx", "hello"), nil)

    // find_all
    let nums = regex.find_all("\\d+", "1 22 333 4444")
    assert_eq(nums.len(), 4)
    assert_eq(nums[3], "4444")

    // replace
    assert_eq(regex.replace("\\d+", "abc 1 def 22 ghi", "N"), "abc N def N ghi")

    // split
    let parts = regex.split("\\s+", "hello   world   foo")
    assert_eq(parts.len(), 3)
    assert_eq(parts[1], "world")

    print("regex ok")
}

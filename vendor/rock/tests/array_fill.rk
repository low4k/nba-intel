fn main() {
    let zeros = [0; 5]
    assert(zeros.len() == 5)
    assert(zeros[0] == 0)
    assert(zeros[4] == 0)

    let ones = [1; 3]
    assert(ones.len() == 3)
    assert(ones[2] == 1)

    let names = ["alice"; 2]
    assert(names[0] == "alice")
    assert(names[1] == "alice")

    let empty = [0; 0]
    assert(empty.len() == 0)

    let normal = [10, 20, 30]
    assert(normal.len() == 3)
    assert(normal[1] == 20)

    print("array fill ok")
}

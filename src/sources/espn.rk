fn search_players(query) {
    let q = espn.urlenc(query)
    let url = `https://site.web.api.espn.com/apis/common/v3/search?limit=10&query=${q}&type=player`
    try {
        let resp = http.get(url)
        if resp["status"] != 200 { return nil }
        return json.parse(resp["body"])
    } catch (e) {
        log.warn(`espn search: ${e}`)
        return nil
    }
}

fn urlenc(s) {
    let mut out = ""
    let mut i = 0
    while i < len(s) {
        let c = s[i]
        if (c >= "a" and c <= "z") or (c >= "A" and c <= "Z") or (c >= "0" and c <= "9") or c == "-" or c == "_" or c == "." or c == "~" {
            out = out + c
        } else if c == " " {
            out = out + "%20"
        } else {
            out = out + "%" + hex.encode(c)
        }
        i = i + 1
    }
    out
}

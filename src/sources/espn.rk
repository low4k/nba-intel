fn team_roster(team_abbr) {
    let url = `https://site.api.espn.com/apis/site/v2/sports/basketball/nba/teams/${strs.lower(team_abbr)}/roster`
    try {
        let resp = http.get(url)
        if resp["status"] != 200 { return nil }
        return json.parse(resp["body"])
    } catch (e) {

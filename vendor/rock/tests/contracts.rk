@require(x > 0)
@ensure(result >= 0)
fn safe_sqrt(x) {
    return sqrt(x)
}

@require(a >= 0, b >= 0)
@ensure(result == a + b)
fn add_nonneg(a, b) {
    return a + b
}

fn caught(thunk) {
    return 0
}

fn main() {
    let r = safe_sqrt(16.0)
    print("sqrt(16) =", r)
    assert_eq(r, 4.0)

    let s = add_nonneg(3, 4)
    print("3+4 =", s)
    assert_eq(s, 7)

    print("ok")
}
